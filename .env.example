# ════════════════════════════════════════════════════════════════
# JWT 多人版配置
# ════════════════════════════════════════════════════════════════

# JWT 簽章密鑰（生產環境請改用 secrets.token_urlsafe(32)）
JWT_SECRET_KEY=your_super_secret_key_here_change_in_production

# JWT Token 過期時間（小時）
JWT_EXPIRY_HOURS=24

# ════════════════════════════════════════════════════════════════
# 多通道即時預測配置
# ════════════════════════════════════════════════════════════════

# 多通道數據拉取間隔（秒）
FETCH_INTERVAL=5

# 盤中交易時間範圍
MARKET_OPEN_TIME=09:00
MARKET_CLOSE_TIME=13:30

# 數據來源 API Keys
TWSE_API_KEY=
FINMIND_API_KEY=
YFINANCE_TIMEOUT=10

# ════════════════════════════════════════════════════════════════
# Flask 運行配置
# ════════════════════════════════════════════════════════════════

FLASK_ENV=development
FLASK_SECRET_KEY=trading_system_flask_secret_key_2026
CORS_ORIGIN=http://localhost:8787
PORT=8080

# ── Telegram Bot 設定 ─────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_IDS=your_chat_id_here

# ── AI 情報分析（選填） ───────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
